# goBlink Hub environment variables
# Copy this file to .env.local and replace placeholder values.

# Public app config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# ─────────────────────────────────────────────────────────────────────────────
# Supabase — three independent projects, unified identity
#
# Hub talks to three Supabase projects:
#   • Blink     — canonical identity (auth.users), audit, swap data, payment links
#   • Merchant  — payment platform (merchants, payments, invoices, payouts)
#   • Book      — sites/pages/subscriptions (bb_*)
#
# Identity is unified on Blink: all three projects share Blink's JWT secret
# so a Blink-issued JWT validates inside Merchant and Book RLS via auth.uid().
# Set the JWT secret in each project's dashboard → Settings → API → JWT Secret.
#
# The legacy NEXT_PUBLIC_SUPABASE_URL / SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY
# vars below are kept as fallbacks for Blink so existing call sites in
# lib/supabase/{client,server,middleware}.ts and lib/server/db.ts keep working
# without rewriting. New code should use lib/supabase/projects.ts which
# accepts BLINK_*, MERCHANT_*, BOOK_* explicitly.
# ─────────────────────────────────────────────────────────────────────────────

# Blink (canonical identity, audit, swap)
# Public values (also exposed via NEXT_PUBLIC_SUPABASE_URL/ANON_KEY for SSR clients).
BLINK_SUPABASE_URL=https://your-blink-project.supabase.co
BLINK_SUPABASE_ANON_KEY=your-blink-anon-key
# Service-role key — NEVER expose to the browser.
BLINK_SUPABASE_SERVICE_ROLE_KEY=your-blink-service-role-key
# JWT signing secret from Blink's dashboard. Used by the wallet-auth endpoint
# to mint Supabase-compatible session tokens. Must MATCH the JWT secret
# configured in Merchant and Book projects so cross-project JWTs validate.
BLINK_SUPABASE_JWT_SECRET=your-blink-jwt-secret

# Legacy / SSR-client compatibility — point at Blink.
NEXT_PUBLIC_SUPABASE_URL=https://your-blink-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-blink-anon-key
SUPABASE_URL=https://your-blink-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-blink-service-role-key

# Merchant
MERCHANT_SUPABASE_URL=https://your-merchant-project.supabase.co
MERCHANT_SUPABASE_ANON_KEY=your-merchant-anon-key
MERCHANT_SUPABASE_SERVICE_ROLE_KEY=your-merchant-service-role-key

# Book
BOOK_SUPABASE_URL=https://your-book-project.supabase.co
BOOK_SUPABASE_ANON_KEY=your-book-anon-key
BOOK_SUPABASE_SERVICE_ROLE_KEY=your-book-service-role-key

# ─────────────────────────────────────────────────────────────────────────────
# Other server secrets
# ─────────────────────────────────────────────────────────────────────────────

ONE_CLICK_BASE_URL=https://1click.chaindefuser.com
ONE_CLICK_JWT=your-oneclick-jwt
# Used to HMAC-sign payment-link completion tokens AND wallet-auth nonces.
SESSION_SECRET=generate-a-random-secret-at-least-32-chars
COOKIE_SECRET=generate-a-random-secret-at-least-32-chars
# Optional — enables authenticated calls to the Intents Explorer API
INTENTS_EXPLORER_JWT=your-intents-explorer-jwt
# Optional — enables fiat exchange-rate refresh jobs
OPEN_EXCHANGE_RATES_APP_ID=your-open-exchange-rates-app-id

# ─────────────────────────────────────────────────────────────────────────────
# Audit feature (zion-prover integration, server-side only)
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the zion-prover HTTP API. No trailing slash.
ZION_API_BASE_URL=http://localhost:3900
# Bearer token sent to the prover. Must match ZION_API_AUTH_TOKEN / ZION_API_TOKENS
# on the prover side.
ZION_API_TOKEN=your-zion-api-token
# Set to "true" to enable /api/zion/audit/github. Prover must also have
# ZION_ENABLE_GITHUB_AUDITS=true set.
ZION_GITHUB_AUDITS_ENABLED=false
# Per-file upload cap in bytes, enforced in the proxy before forwarding.
# Prover caps each file at 10 MiB; keep this <= 10485760.
ZION_MAX_UPLOAD_BYTES=10485760
# Request timeout for audit submit and resubmit (ms).
ZION_REQUEST_TIMEOUT_MS=30000
# Request timeout for report downloads (ms). PDFs take longer.
ZION_REPORT_TIMEOUT_MS=60000

# Fee config (optional)
APP_FEE_BPS=35
APP_FEE_RECIPIENT=goblink.near
FEE_TIERS=[{"maxAmountUsd":5000,"bps":35},{"maxAmountUsd":50000,"bps":10},{"maxAmountUsd":null,"bps":5}]

# RPC overrides (optional, defaults exist in code)
SUI_RPC_URL=https://fullnode.mainnet.sui.io
NEAR_RPC_URL=https://rpc.fastnear.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
ETHEREUM_RPC_URL=https://eth.llamarpc.com
BASE_RPC_URL=https://mainnet.base.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
BSC_RPC_URL=https://bsc-dataseed1.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com
OPTIMISM_RPC_URL=https://mainnet.optimism.io
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
GNOSIS_RPC_URL=https://rpc.gnosischain.com
BERACHAIN_RPC_URL=https://rpc.berachain.com
MONAD_RPC_URL=https://rpc.monad.xyz
AURORA_RPC_URL=https://mainnet.aurora.dev
PLASMA_RPC_URL=https://rpc.plasma.cash
XLAYER_RPC_URL=https://rpc.xlayer.tech
ADI_RPC_URL=https://rpc.adichain.io
